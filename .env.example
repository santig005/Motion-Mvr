# Copy this file to ".env" and fill in your camera's values.
# Get them from your camera's app / settings -> RTSP.
# ".env" is gitignored so the password never gets committed.

CAMERA_IP=192.168.1.50
CAMERA_RTSP_PORT=554
CAMERA_RTSP_USER=YOUR_USER
CAMERA_RTSP_PASSWORD=YOUR_PASSWORD
CAMERA_NAME=cam1

FRIGATE_RTSP_PASSWORD=YOUR_PASSWORD
