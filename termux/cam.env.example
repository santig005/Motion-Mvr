# Motion recorder config for Termux. Copy to ~/cam1.env and fill in your values.
# Do NOT commit your real cam.env (it holds credentials).
#
# MULTI-CAMERA: one config per camera (cam1.env, cam2.env, ...), each with its own RTSP, its OUT_DIR
# (Cameras/cam1, Cameras/cam2, ...) and its LOG. Run them as separate tmux sessions:
#   tmux new-session -d -s cam1 "cd ~ && CAM_ENV=~/cam1.env exec ./record-preroll.sh"
# A single instance (cloud-sync.sh) uploads the whole /sdcard/Movies/Cameras root to the cloud.

# RTSP URL of the stream that gets RECORDED on trigger (2K, ch0).
# Replace USER:PASS and CAMERA_IP with your camera's RTSP credentials and IP.
RTSP_MAIN="rtsp://USER:PASS@CAMERA_IP:554/live/ch0"

# Stream to DETECT on. Default = RTSP_MAIN. To save CPU (~5x), detect on the 360p sub-stream (ch1)
# and record the 2K (ch0). 360p reliably catches people/doorways (validated day and night):
RTSP_DETECT="rtsp://USER:PASS@CAMERA_IP:554/live/ch1"

# RTSP read timeout in microseconds (10s). If the stream stalls, ffmpeg FAILS FAST (doesn't hang)
# and the supervisor reconnects. Don't go below a few seconds:
RTSP_TIMEOUT="10000000"

# Output folder for the clips, per camera. Under /sdcard/... it stays VISIBLE in Gallery/VLC
# (requires 'termux-setup-storage'). No transcode: the 2K master is recorded as-is; play it with
# VLC in software mode (Settings > Hardware acceleration > Disabled) on low-end phones.
OUT_DIR="/sdcard/Movies/Cameras/cam1"

# Per-camera log (one per camera so they don't mix):
LOG="$HOME/logs/cam1.motion.log"

# (Optional) Path of the per-clip metrics CSV. Default: $OUT_DIR/metrics.csv
# METRICS="$OUT_DIR/metrics.csv"

# Analysis fps (lower = less CPU/battery; 3 ~ 60% of one core on a low-end phone):
DET_FPS="3"

# ROI: region to analyze (W:H:X:Y) IN THE DETECTION STREAM'S COORDS. Crop to the walkable area
# (discards static walls). Empty = full frame.
#   - if detecting on 2K (ch0):   760:1296:818:0
#   - if detecting on 360p (ch1): 210:360:226:0   <-- use this with RTSP_DETECT=ch1
DET_CROP="210:360:226:0"

# Per-pixel threshold (0-255): a pixel counts as "changed" if it differs more than this (above noise):
DIFF_TH="20"

# Trigger threshold: fraction of changed pixels. In a hallway scene: idle < 0.01; weakest real
# motion (hands/far away) ~0.6; walking ~5-50; light/door false positives = 1-frame flickers.
# 0.4 sits below the 0.6 real floor (doesn't miss motion) and trims the weak flickers:
YAVG_TH="0.4"

# Debounce: CONSECUTIVE frames over the threshold to trigger. 1 = as before (1 frame);
# 2 = anti-noise (noise/light lasts 1 frame, real motion persists). Recommended: 2.
DEBOUNCE="2"

# Discard clips shorter than this (s): corrupt RTSP fragments show up as 0.1s / 4KB:
MIN_CLIP="1.5"

# --- PRE-ROLL mode (record-preroll.sh) ---
# Records the 2K continuously (ring buffer) and keeps the segments with motion, including the
# seconds BEFORE the trigger.
RING_DIR="/sdcard/Movies/.ring/cam1"     # segment ring; MUST live OUTSIDE /sdcard/Movies/Cameras
SEG_TIME="4"                             # segment target (real ~camera GOP, ~12s)
# Pre/post-roll in EXACT SECONDS. The final clip is trimmed to
# [motion_start - PREROLL, motion_end + POSTROLL]. Tight clips, no 12s blocks.
PREROLL="3"
POSTROLL="3"
TAIL_PAD="2.5"                           # seconds of tail after the last REAL motion on the 2K
RING_KEEP_MIN="5"                        # minutes an idle segment lives in the ring before deletion

# --- Cloud upload is configured separately, in ~/cloud.env (used by cloud-sync.sh, not this file). ---
# Example ~/cloud.env:
#   CAMERAS_DIR="/sdcard/Movies/Cameras"   # local root of all cameras
#   RCLONE_REMOTE="gdrive:Cameras"          # root on Drive
#   LOCAL_KEEP_DAYS="7"; CLOUD_KEEP_DAYS="30"; SYNC_INTERVAL="120"
